{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "water-plant": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "standalone": true,
          "type": "component",
          "style": "less",
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "type": "directive"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "hw",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "less",
            "assets": [
              "src/favicon.ico",
              "src/assets",
              "src/assets/config/config.json",
              "src/web.config",
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.less",
              "node_modules/ngx-toastr/toastr.css",
              "src/assets/js/bootstrap/datetimepicker/bootstrap-datetimepicker-dark.css",
              "src/assets/js/bootstrap/datetimepicker/bootstrap-datetimepicker.css"
            ],
            "scripts": [
              "src/assets/js/jquery/jquery-3.7.1.min.js",
              "src/assets/js/bootstrap/datetimepicker/bootstrap-datetimepicker.js",
              "src/assets/js/bootstrap/datetimepicker/bootstrap-datetimepicker.zh-CN.js",
              "src/assets/js/base64.js",
              "src/assets/js/guid.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.ts"
          },
          "configurations": {
            "production": {
              "buildTarget": "water-plant:build:production"
            },
            "development": {
              "buildTarget": "water-plant:build:development",
              "host": "127.0.0.1",
              "port": 9000,
              "open": false
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}